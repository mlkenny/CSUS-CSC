#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>

int main(int argc, char *argv[]) {
	int fp;
	char buffer[10];
	pid_t pid;

	if(argc != 2) {
		printf("fileForkLoop: usage <filename>\n");
		exit(1);
	}

	fp = open(argv[1], O_WRONLY | O_CREAT | O_TRUNC, S_IRUSR | S_IWUSR);

	if(fp == -1) {
		printf("fileForkLoop: Error opening file.\n");
		exit(1);
	}

	pid = fork();
	
	if(pid != 0) {
		int i;
		int len;
		// Attempt to write to file with parent.
		if(write(fp, "Parent attempting to write.\n", 29) == -1) {
			printf("fileForkLoop: Error writing to file.\n");
			close(fp);
			exit(1);
		}
		for(i = 1; i <= 5; i++) {
			write(fp, "Parent: \n", 10);
			len = snprintf(buffer, sizeof(buffer), "%d\n", i);
			write(fp, buffer, len);
		}
	} else {
		int i;
		int len;
		// Attempt to write to file with the child process.
		if(write(fp, "Child attempting to write.\n", 28) == -1) {
			printf("fileForkLoop: Error writing to file.\n");
			close(fp);
			exit(1);
		}
		for(i = 10; i <= 15; i++) {
			write(fp, "Child: \n", 9);
			len = snprintf(buffer, sizeof(buffer), "%d\n", i);
			write(fp, buffer, len);
		}
		exit(0);
	}

	return 0;
}
